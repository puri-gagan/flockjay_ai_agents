# Required. Gemini SDK
GEMINI_API_KEY=

# Optional. Needed when LLM_MODEL (in app/constants.py) targets that provider.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Required. Callers must send `x-api-key: <API_KEY>` on /chat.
# Generate with: openssl rand -hex 32
API_KEY=

# Optional — defaults shown.
FLOCKJAY_MCP_URL=https://api-demo.flockjay.com/mcp
PORT=8000

# Optional. Set OPIK_API_KEY to enable per-turn agent tracing.
OPIK_API_KEY=
OPIK_WORKSPACE=default
OPIK_PROJECT_NAME=flockjay-agents
