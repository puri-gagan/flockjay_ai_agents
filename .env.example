# API keys — set whichever provider(s) your configured LLM_MODEL and
# EMBEDDING_MODEL (both in app/constants.py) target. Defaults use Gemini
# for both, so GEMINI_API_KEY is required out of the box.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Required. Callers must send `x-api-key: <API_KEY>` on /chat.
# Generate with: openssl rand -hex 32
API_KEY=

# Optional — defaults shown.
FLOCKJAY_MCP_URL=https://api-demo.flockjay.com/mcp
PORT=8000

# Optional. Set OPIK_API_KEY to enable per-turn agent tracing.
OPIK_API_KEY=
OPIK_WORKSPACE=default
OPIK_PROJECT_NAME=flockjay-agents
